{
    "configurations": [
        {
            // ESP32 firmware — IntelliSense provided by the ESP-IDF extension.
            "name": "ESP32 (IDF)",
            "compilerPath": "${env:HOME}/.espressif/tools/xtensa-esp-elf/esp-13.2.0_20230928/xtensa-esp-elf/bin/xtensa-esp32-elf-gcc",
            "cStandard": "c17",
            "cppStandard": "c++17",
            "intelliSenseMode": "gcc-arm",
            "configurationProvider": "espressif.esp-idf-extension"
        },
        {
            // Host-native tests — uses the system Clang on macOS.
            "name": "Native (Tests)",
            "compilerPath": "/usr/bin/clang++",
            "cStandard": "c17",
            "cppStandard": "c++17",
            "intelliSenseMode": "clang-arm64",
            "includePath": [
                "${workspaceFolder}/components/**",
                "${workspaceFolder}/tests/build/debug/generators"
            ]
        }
    ],
    "version": 4
}
