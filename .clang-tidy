---
# Run on all project headers; adjust the regex if you add more directories.
HeaderFilterRegex: '(components|main)/.*\.(h|hpp)$'

Checks: >-
  clang-diagnostic-*,
  clang-analyzer-*,
  cppcoreguidelines-*,
  modernize-*,
  performance-*,
  readability-*,
  -modernize-use-trailing-return-type,
  -readability-magic-numbers,
  -cppcoreguidelines-avoid-magic-numbers,
  -cppcoreguidelines-pro-bounds-array-to-pointer-decay,
  -cppcoreguidelines-pro-type-vararg

# Promote warnings to errors in CI — set to '*' to enforce all.
WarningsAsErrors: ''

# Apply .clang-format rules when clang-tidy suggests formatting changes.
FormatStyle: file

CheckOptions: []
